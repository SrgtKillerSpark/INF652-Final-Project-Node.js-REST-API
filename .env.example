# Copy this file to .env and fill in the values.
# DO NOT commit the actual .env file to GitHub.

# MongoDB connection string (Atlas SRV URI). Example:
# DATABASE_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/statesDB?retryWrites=true&w=majority
DATABASE_URI=

# Port for the server (optional - hosts like Glitch/Render set this automatically)
PORT=3500
